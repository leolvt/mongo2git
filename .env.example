# mongo2git — environment variables
# Copy this file to .env and fill in the values.

# MongoDB connection string. Must include the database name.
# Format: mongodb://[user:pass@]host[:port]/dbname[?options]
MONGO_URI=mongodb://localhost:27017/mydb

# MongoDB collection to export and version in git.
MONGO_COLLECTION=mycollection

# Subdirectory inside the cloned repo where JSON files are written.
# Can be nested (e.g., backups/daily).
DUMP_DIR=data

# Local path where the git repository will be cloned.
# The parent directory must exist and be writable.
CLONE_DIR=/path/to/local/clone

# Git remote URL (SSH recommended for automated pushes).
# Example: git@github.com:user/repo.git
REPO_URL=git@github.com:user/backups.git

# Git branch to push to.
# Optional — defaults to "main".
# GIT_BRANCH=main

# Slack incoming webhook URL for backup notifications.
# Optional — notifications are logged to stdout if not set.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00/B00/xxx
